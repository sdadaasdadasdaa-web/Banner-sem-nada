# Proteção da pasta config - Bloqueia acesso direto via web
# Este arquivo impede que arquivos sensíveis sejam acessados diretamente

# Nega acesso a todos os arquivos nesta pasta
<IfModule mod_authz_core.c>
    # Apache 2.4+
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    # Apache 2.2
    Order Allow,Deny
    Deny from all
</IfModule>

# Proteção extra para arquivos específicos
<FilesMatch "\.(php|txt|json|env|ini|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
